import { useState } from "react";

const StudentRegister = () => {
  const [form, setForm] = useState({
    name: "", rollNo: "", college: "", department: "",
    year: "", email: "", password: ""
  });

  const handleChange = (e) =>
    setForm({ ...form, [e.target.name]: e.target.value });

  const handleSubmit = (e) => {
    e.preventDefault();
    console.log("Student Registered:", form);
  };

  return (
    <div className="register-container">
      <h2>Student Registration</h2>
      <form onSubmit={handleSubmit}>
        <input name="name" placeholder="Full Name" onChange={handleChange} required />
        <input name="rollNo" placeholder="Roll Number" onChange={handleChange} required />
        <input name="college" placeholder="College Name" onChange={handleChange} required />
        <input name="department" placeholder="Department" onChange={handleChange} required />
        <select name="year" onChange={handleChange} required>
          <option value="">Select Year</option>
          <option>1st Year</option>
          <option>2nd Year</option>
          <option>3rd Year</option>
        </select>
        <input name="email" type="email" placeholder="Email" onChange={handleChange} required />
        <input name="password" type="password" placeholder="Password" onChange={handleChange} required />
        <button type="submit">Register</button>
      </form>
    </div>
  );
};

export default StudentRegister;
